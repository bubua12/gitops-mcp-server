apiVersion: v1
kind: Secret
metadata:
  name: gitops-mcp-secrets
  namespace: gitops-mcp
  labels:
    app.kubernetes.io/name: gitops-mcp-server
type: Opaque
data:
  # base64 编码的 GitHub Token
  # 生成方式：echo -n "ghp_your_token" | base64
  github-token: Z2hwX3h4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eHh4eA==
  # 可选：API Key（留空字符串表示不启用）
  # 生成方式：echo -n "your_api_key" | base64
  api-key: ""
